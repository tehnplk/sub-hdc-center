# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าตามสภาพแวดล้อม
# - รันผ่าน docker compose: DB_HOST=db, DB_PORT=5432
# - รันตรงบนเครื่อง (npm run dev): DB_HOST=localhost, DB_PORT=5436 (พอร์ตที่ compose map ออกมา)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=sub_hdc_center
DATABASE_URL=postgres://postgres:your_password@db:5432/sub_hdc_center
